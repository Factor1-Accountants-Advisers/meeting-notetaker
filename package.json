{
  "name": "meeting-notetaker",
  "version": "1.0.0",
  "description": "Slice 1 — Auto-triggered recording, Pyannote speaker ID, Graph email, UI modernisation",
  "main": "./out/main/index.js",
  "author": "Factor1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "verify:graph": "esbuild scripts/verify-graph-fixtures.ts --bundle --platform=node --format=cjs --outfile=out/verify-graph-fixtures.cjs --log-level=error --external:electron && node out/verify-graph-fixtures.cjs",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir",
    "package:win": "node scripts/prepackage.js && electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.3",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "fix-webm-duration": "^1.0.6",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
