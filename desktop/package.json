{
  "name": "meeting-notetaker-desktop",
  "version": "1.1.9",
  "description": "Meeting Note-Taker desktop agent",
  "main": "dist/main/index.js",
  "scripts": {
    "build:web": "cd ../web && npx next build && cd ../desktop && node -e \"require('fs').cpSync('../web/out', 'web-out', { recursive: true })\"",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json && node -e \"require('fs').cpSync('src/renderer/meeting-selector/index.html','dist/renderer/meeting-selector/index.html'); require('fs').cpSync('src/renderer/wasapi/index.html','dist/renderer/wasapi/index.html')\"",
    "build": "npm run build:web && npm run build:electron",
    "copy:html": "node -e \"require('fs').cpSync('src/renderer/meeting-selector/index.html','dist/renderer/meeting-selector/index.html'); require('fs').cpSync('src/renderer/wasapi/index.html','dist/renderer/wasapi/index.html')\"",
    "dev": "npm run copy:html && concurrently -n web,tsc-main,tsc-rend,electron \"cd ../web && npx next dev\" \"tsc -w -p tsconfig.main.json\" \"tsc -w -p tsconfig.renderer.json\" \"wait-on http://localhost:3000 && electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "test": "jest"
  },
  "keywords": [],
  "author": "Factor1",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@azure/msal-node": "^2.0.0",
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.0.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0"
  }
}
