# .env.production — bundled inside the MSI via electron-builder extraResources.
# Loaded at runtime by loadEnv() in src/main/runtime-paths.ts.
#
# SETUP:
#   1. Copy this file to desktop/.env.production (gitignored)
#   2. Fill in real values before running: npm run dist:win
#
# In CI (GitHub Actions) this file is generated from repository secrets.
# See .github/workflows/release.yml for the full list of required secrets.

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Azure AD (SSO login) ───────────────────────────────────────────────────────
# From: Azure Portal → App registrations → your app
AZURE_AD_TENANT_ID=your-tenant-guid-here
AZURE_AD_CLIENT_ID=your-client-guid-here
AZURE_AD_CLIENT_SECRET=your-client-secret-here

# ── AI services ────────────────────────────────────────────────────────────────
# AssemblyAI: https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your-assemblyai-key-here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Auto-updater ───────────────────────────────────────────────────────────────
# A GitHub fine-grained personal access token so the installed app can download
# future update MSIs from the private GitHub Releases page.
#
# Create one at: https://github.com/settings/tokens?type=beta
#   Repository:  guerrerojoseph/meeting-notetaker
#   Permission:  Contents → Read-only
#   Expiration:  1 year (renew annually, then rebuild + redistribute the MSI)
#
# This token is embedded in every MSI you ship. It only has read access to
# release assets on this single private repo — low risk for an internal tool.
GH_TOKEN=github_pat_...
