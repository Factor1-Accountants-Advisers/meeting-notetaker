# Copy to .env and fill in values (same app registration as the Notetaker desktop app).
# You can copy AZURE_AD_* from meeting-notetaker-main/desktop/.env.local if you have it.

AZURE_AD_TENANT_ID=891d380b-39a6-4eb4-aca5-4ffe1d3c25ac
AZURE_AD_CLIENT_ID=3e3f3422-d4fa-4ebe-9b22-148439e84cc3

# Comma-separated test recipients (simulates calendar invitees).
# External domains are filtered out automatically — only @factor1.com.au is sent.
TEST_RECIPIENTS=davidahlhaus@factor1.com.au,davidahlhaus@yahoo.com.au

# Optional: path to attachment (defaults to sample-meeting-notes.md in this folder)
# ATTACHMENT_PATH=./sample-meeting-notes.md
