# Meeting Note-Taker Environment Schema
# This file defines environment variables, their types, and sensitivity levels.
#
# IMPORTANT: This file contains NO secrets - only schema definitions.
# Actual values go in .env (which is gitignored).
#
# @defaultSensitive=true @defaultRequired=infer

# =============================================================================
# Environment
# =============================================================================

# @type=enum(development,staging,production) @sensitive=false @required
ENVIRONMENT=development

# =============================================================================
# Azure AD Authentication
# =============================================================================

# @type=string @sensitive=false @required
# Azure AD Tenant ID (GUID format)
AZURE_AD_TENANT_ID=

# @type=string @sensitive=false @required
# Azure AD Application/Client ID (GUID format)
AZURE_AD_CLIENT_ID=

# @type=string @sensitive @required
# Azure AD Client Secret - NEVER expose this value
AZURE_AD_CLIENT_SECRET=

# =============================================================================
# Azure Blob Storage (Production)
# =============================================================================

# @type=string @sensitive @required=false
# Azure Storage connection string - contains account key
# Leave empty for local development (uses MinIO instead)
AZURE_STORAGE_CONNECTION_STRING=

# @type=string @sensitive=false
# Container name for audio files
AZURE_STORAGE_CONTAINER_NAME=meeting-audio

# =============================================================================
# MinIO (Local Development)
# =============================================================================

# @type=url @sensitive=false
# MinIO endpoint URL
MINIO_ENDPOINT=http://minio:9000

# @type=string @sensitive
# MinIO access key (like AWS access key)
MINIO_ACCESS_KEY=

# @type=string @sensitive
# MinIO secret key (like AWS secret key)
MINIO_SECRET_KEY=

# =============================================================================
# Database
# =============================================================================

# @type=url @sensitive @required
# PostgreSQL connection URL - contains password
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=

# =============================================================================
# Redis
# =============================================================================

# @type=url @sensitive=false @required
# Redis connection URL (no auth in development)
REDIS_URL=redis://redis:6379/0

# =============================================================================
# AI Services
# =============================================================================

# @type=string(startsWith=sk-ant-) @sensitive @required
# Anthropic API key for Claude summarization
ANTHROPIC_API_KEY=

# @type=string(startsWith=hf_) @sensitive @required
# HuggingFace token for Pyannote speaker diarization
HF_TOKEN=

# =============================================================================
# Whisper Configuration
# =============================================================================

# @type=enum(tiny,base,small,medium,large,large-v2,large-v3) @sensitive=false
# Whisper model size (medium for dev, large-v3 for production)
WHISPER_MODEL=medium
