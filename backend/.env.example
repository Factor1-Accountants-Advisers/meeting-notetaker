# Meeting Notetaker backend configuration (pydantic-settings, prefix MN_).
# Copy to .env for local overrides. In deployed environments these come from
# Azure Key Vault / app settings — never commit real values.

MN_ENVIRONMENT=dev

# --- Azure resources (empty = local stubs take over) -----------------------
# Blob Storage account for meeting audio (30-day lifecycle policy on the
# container). Local stand-in: backend/var/audio.
MN_BLOB_ACCOUNT_URL=

# Azure Database for PostgreSQL connection string. Empty = JSON-snapshot
# store (backend/var/store.json). Setting this triggers the SQLAlchemy
# repository work.
MN_POSTGRES_DSN=

# Key Vault for application-layer encryption keys (voiceprints) and Graph
# credentials. Also gates the GraphEmailProvider.
MN_KEY_VAULT_URL=

# Azure AI Speech (batch transcription + diarization). Empty = stub
# transcript provider.
MN_SPEECH_ENDPOINT=

# Azure OpenAI (summaries + action items). BOTH must be set to switch off
# the stub LLM provider.
MN_OPENAI_ENDPOINT=
MN_OPENAI_DEPLOYMENT=

# --- Tuning -----------------------------------------------------------------
# Cosine-similarity cutoff for voiceprint matching; tune on real Factor1 audio.
MN_SIMILARITY_THRESHOLD=0.62
MN_PYANNOTE_MODEL_VERSION=pyannote/embedding-3.1

# Raw-audio retention window (requirements 6.2 engineering default).
MN_AUDIO_RETENTION_DAYS=30
