# Meeting Notetaker — per-machine credentials file
#
# Copy this template to:
#   %PROGRAMDATA%\Factor1\MeetingNotetaker\backend.env
#
# The Electron supervisor reads this file at startup and merges every
# KEY=VALUE line into the backend child process environment.  Lines
# starting with # are ignored.  Missing or empty values leave the
# corresponding provider in stub/dev mode.
#
# DO NOT commit real keys here — this file ships with placeholders only.

# OpenAI API (summaries + action items).  Direct API key OR Azure endpoint.
# MN_OPENAI_API_KEY=sk-REPLACE_ME
# MN_OPENAI_ENDPOINT=https://REPLACE_ME.openai.azure.com
# MN_OPENAI_DEPLOYMENT=REPLACE_ME

# PyannoteAI (transcription + voiceprint speaker ID).
# MN_PYANNOTE_API_KEY=REPLACE_ME

# SharePoint transcript delivery (Graph delegated, per-user consent).
# MN_SHAREPOINT_DRIVE_ID=REPLACE_ME
# MN_SHAREPOINT_FOLDER_PATH=Notetaker Transcripts

# Azure Blob (audio upload; later slice — stub today).
# MN_BLOB_ACCOUNT_URL=https://REPLACE_ME.blob.core.windows.net
