# Meeting Notetaker — per-machine credentials file
#
# Copy this template to:
#   %PROGRAMDATA%\Factor1\MeetingNotetaker\backend.env
#
# The Electron supervisor reads this file at startup and merges every
# KEY=VALUE line into the backend child process environment.  Lines
# starting with # are ignored.  Missing or empty values leave the
# corresponding provider in stub/dev mode.
#
# DO NOT commit real keys here — this file ships with placeholders only.

# OpenAI API (summaries + action items).  Direct API key OR Azure endpoint.
# MN_OPENAI_API_KEY=sk-REPLACE_ME
# MN_OPENAI_ENDPOINT=https://REPLACE_ME.openai.azure.com
# MN_OPENAI_DEPLOYMENT=REPLACE_ME

# PyannoteAI (transcription + voiceprint speaker ID).
# MN_PYANNOTE_API_KEY=REPLACE_ME

# Authenticated Storage API (public configuration; no secret or Blob
# credential). Production defaults are built into Electron main and inherited
# by the packaged backend:
# MN_STORAGE_API_URL=https://func-innov-nt-storage-prod-eqg7dzf8gfbqawea.australiaeast-01.azurewebsites.net
# MN_STORAGE_API_SCOPE=api://13298042-714a-4d57-a1c5-481c22753087/access_as_user
#
# Operational rollback: set MN_STORAGE_API_ENABLED=false in the Electron
# process environment or its .env.production override so main and backend agree.
# Setting it only in this backend.env disables central calls in FastAPI, but
# Electron main may still acquire an unused delegated token.
# MN_STORAGE_API_ENABLED=true

# Voiceprint candidate expansion (IN-79): comma-separated employee emails
# considered for manual/ad-hoc recordings after the attendee/recorder pass.
# Without this, manual recordings only match the recorder's own voiceprint.
# MN_VOICEPRINT_EXPANSION_EMPLOYEE_IDS=person1@factor1.com.au,person2@factor1.com.au
# MN_VOICEPRINT_EXPANSION_CAP=10

# Diarization speaker-count hint (IN-86): set to the known number of speakers
# to help pyannote separate voices in pre-mixed call audio. 0 or unset = off.
# MN_PYANNOTE_NUM_SPEAKERS=0

# SharePoint transcript delivery (Graph delegated, per-user consent).
# MN_SHAREPOINT_DRIVE_ID=REPLACE_ME
# MN_SHAREPOINT_FOLDER_PATH=Notetaker Transcripts

# Azure Blob (audio upload; later slice — stub today).
# MN_BLOB_ACCOUNT_URL=https://REPLACE_ME.blob.core.windows.net
